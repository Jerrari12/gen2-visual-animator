  "steps": [
    {
      "title": "Print checklist",
      "note": "68 prints · quantities on the right. You'll also need 10× M3 screws for the handles (2 each) and 10× 10×2 mm disc magnets for the optional magnet closures (hardware store items).",
      "camera": { "t": 28, "p": 60, "r": 1450, "target": [0, 95, 60] },
      "checklist": true
    },
    {
      "title": "Bench: lower footrails",
      "note": "A 3W base uses a 2W and a 1W lower footrail side by side. We show them raised so you can see the foot slots on the undersides.",
      "camera": { "t": 30, "p": 55, "r": 780, "target": [0, 115, 0] },
      "phases": [ { "enter": [ { "id": "frl2w", "from": [0, 90, 0] }, { "id": "frl1w", "from": [0, 90, 0] } ] } ]
    },
    {
      "title": "Bench: insert the eight feet",
      "note": "Pointy end slides in first · outer feet toward the rail ends, middle feet left to right. Where the two rails meet, the slots would put feet right next to each other: install that pair on ONE rail only (we use the 2W's).",
      "camera": { "t": 30, "p": 55, "r": 780, "target": [0, 115, 0] },
      "phases": [
        { "enter": [
          { "id": "f1", "from": [ 30, 0, 0] },
          { "id": "f3", "from": [-30, 0, 0] },
          { "id": "f5", "from": [-30, 0, 0] },
          { "id": "f7", "from": [-30, 0, 0] }
        ] },
        { "enter": [
          { "id": "f2", "from": [ 30, 0, 0] },
          { "id": "f4", "from": [-30, 0, 0] },
          { "id": "f6", "from": [-30, 0, 0] },
          { "id": "f8", "from": [-30, 0, 0] }
        ] }
      ]
    },
    {
      "title": "Set the base down",
      "note": "Flip the base feet-down and set it where the kit will live.",
      "camera": { "t": 30, "p": 60, "r": 860, "target": [0, 50, 0] },
      "phases": [ { "settle": "base" } ]
    },
    {
      "title": "Upper footrails",
      "note": "Each upper footrail slides onto its lower rail from the back, all the way forward until it stops.",
      "camera": { "t": 30, "p": 58, "r": 800, "target": [0, 30, 0] },
      "phases": [ { "enter": [ { "id": "fru2w", "from": [0, 0, -170] }, { "id": "fru1w", "from": [0, 0, -170] } ] } ]
    },
    {
      "title": "Case 1 (2W) · QuickLocks, clip, then slide",
      "note": "QuickLocks go in the OUTER walls only: L left, R right · one pair per case, whatever its width. Optional magnet closure: on a 2W the clip goes in the LEFT back-wall slot; press the magnet in back-to-front, lower the clip, then slide the case on.",
      "camera": { "t": 30, "p": 58, "r": 800, "target": [-44, 45, 0] },
      "phases": [
        { "enter": [ { "id": "caseA", "from": [0, 60, 0] } ] },
        { "enter": [ { "id": "qlAL", "from": [0, 55, 0] }, { "id": "qlAR", "from": [0, 55, 0] } ] },
